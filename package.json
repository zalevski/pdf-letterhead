{
  "name": "pdf-letterhead",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop app for overlaying PDF letterheads onto input PDFs.",
  "main": "dist-electron/electron/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:main\" \"npm:dev:electron\"",
    "dev:renderer": "nuxt dev",
    "dev:electron:main": "tsc -p electron/tsconfig.json -w --preserveWatchOutput",
    "dev:electron": "wait-on http://localhost:3000 dist-electron/electron/main/index.js && electron dist-electron/electron/main/index.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "nuxt build && node scripts/postprocess-nuxt-static.mjs",
    "build:electron": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run dev",
    "electron:build": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nuxt/icon": "^2.2.3",
    "@nuxt/ui": "^4.9.0",
    "nuxt": "^4.0.0",
    "pdf-lib": "^1.17.1",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.pdfletterhead.app",
    "productName": "PDF Letterhead",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".output/public",
        "to": "renderer"
      }
    ],
    "asar": true,
    "npmRebuild": false,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
